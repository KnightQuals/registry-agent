# ===== 模型抽象层（core/model.py）=====
# 默认接实验室服务器本地 LLM（vLLM 部署的 Qwen3）。不填即用下面默认值。
# 若你有更好的模型，改这三项即可切到 Claude / GPT / 中转站等任意 OpenAI 兼容服务。
LLM_BASE_URL=http://127.0.0.1:8502/v1
LLM_API_KEY=EMPTY
LLM_MODEL=qwen
# 可选调参
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# ===== 内置工具 =====
# 心知天气（tools/weather.py）
SENIVERSE_API_KEY=your_seniverse_api_key
# 远程多媒体检索服务（tools/media.py）
REMOTE_MEDIA_SERVICE_URL=http://127.0.0.1:8600/api/search

# ===== 存储路径（可选，默认见代码）=====
# 会话记忆 SQLite（core/memory.py）
# MEMORY_DB=./config/memory.sqlite3
# trace 日志目录（core/trace.py）
# TRACE_DIR=./logs

# ===== 上下文控制（v2.1）=====
# 未压缩消息超过该数时触发 L2 历史摘要；最近完整消息保留数量
MEMORY_SUMMARY_THRESHOLD=30
MEMORY_KEEP_RECENT=12
# 工具数量超过该值才启用工具路由。路由无可靠匹配时自动回退为全量工具。
TOOL_ROUTER_MAX_CANDIDATES=12

# ===== 兼容旧变量（_archive 里的 v1 代码用，v2 不再需要）=====
# QWEN_API_URL=http://127.0.0.1:8502/v1/chat/completions
# QWEN_MODEL_NAME=qwen
